{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://diagramkit.dev/schemas/diagramkit-cli-render.v1.json",
  "title": "diagramkit CLI render envelope v1",
  "type": "object",
  "required": ["schemaVersion", "command", "target", "phase", "options"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "command": {
      "type": "string",
      "const": "render"
    },
    "target": {
      "type": "object",
      "required": ["kind", "path"],
      "properties": {
        "kind": { "enum": ["file", "directory"] },
        "path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "phase": {
      "enum": ["dry-run", "execute"]
    },
    "options": {
      "type": "object"
    },
    "result": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
