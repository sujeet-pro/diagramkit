{
  "name": "diagramkit",
  "version": "0.3.2",
  "description": "Diagram rendering CLI & library — convert .mermaid, .excalidraw, .drawio, and .dot/.gv Graphviz diagrams to SVG/PNG/JPEG/WebP/AVIF with light/dark mode support",
  "keywords": [
    "avif",
    "cli",
    "cli-tool",
    "dark-mode",
    "dark-mode-diagrams",
    "diagram",
    "diagram-renderer",
    "diagram-to-image",
    "draw.io",
    "drawio",
    "drawio-to-svg",
    "excalidraw",
    "excalidraw-to-svg",
    "graphviz",
    "graphviz-to-svg",
    "headless-rendering",
    "incremental-build",
    "jpeg",
    "light-mode",
    "mermaid",
    "mermaid-to-svg",
    "png",
    "rendering",
    "sharp",
    "svg",
    "watch-mode",
    "webp"
  ],
  "homepage": "https://projects.sujeet.pro/diagramkit/",
  "bugs": {
    "url": "https://github.com/sujeet-pro/diagramkit/issues"
  },
  "license": "MIT",
  "author": "Sujeet Jaiswal (https://github.com/sujeet-pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/diagramkit.git"
  },
  "bin": {
    "diagramkit": "./dist/cli/bin.mjs"
  },
  "files": [
    "dist",
    "schemas",
    "ai-guidelines",
    "skills",
    "REFERENCE.md",
    "CHANGELOG.md",
    "llms.txt",
    "llms-full.txt",
    "!dist/**/*.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    },
    "./color": {
      "types": "./dist/color/index.d.mts",
      "import": "./dist/color/index.mjs"
    },
    "./convert": {
      "types": "./dist/convert.d.mts",
      "import": "./dist/convert.mjs"
    },
    "./validate": {
      "types": "./dist/validate.d.mts",
      "import": "./dist/validate.mjs"
    },
    "./schemas/diagramkit-cli-render.v1.json": "./schemas/diagramkit-cli-render.v1.json",
    "./schemas/diagramkit-config.v1.json": "./schemas/diagramkit-config.v1.json",
    "./ai-guidelines/*": "./ai-guidelines/*",
    "./llms": "./llms.txt",
    "./llms-full": "./llms-full.txt",
    "./agents/usage": "./ai-guidelines/usage.md",
    "./agents/diagram-authoring": "./ai-guidelines/diagram-authoring.md"
  },
  "scripts": {
    "prepack": "npm run build:lib",
    "build": "npm run build:lib",
    "build:all": "npm run build:lib && npm run build:docs",
    "build:lib": "vp pack",
    "build:docs": "node --experimental-strip-types --no-warnings ./scripts/run-pagesmith.ts build && node --experimental-strip-types --no-warnings ./scripts/copy-llms.ts",
    "prebuild:docs": "npm run render:docs",
    "preview": "npm run build:all && npm run preview:docs",
    "preview:docs": "node --experimental-strip-types --no-warnings ./scripts/run-pagesmith.ts preview",
    "dev": "npm run dev:docs",
    "dev:docs": "node --experimental-strip-types --no-warnings ./scripts/run-pagesmith.ts dev",
    "predev:docs": "npm run render:docs",
    "render:docs": "npm run build:lib --if-present --silent && node ./dist/cli/bin.mjs render docs/",
    "ai:init": "pagesmith-docs init --ai --no-llms --yes --config ./pagesmith.config.json5",
    "test": "vp test run",
    "test:unit": "vp test run src/ scripts/ --pool forks --fileParallelism",
    "test:unit:watch": "vp test src/ scripts/",
    "test:e2e": "vp test run e2e/ --pool forks --fileParallelism",
    "test:coverage": "vp test run --coverage",
    "test:watch": "vp test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist gh-pages",
    "cicd": "npm run check && npm run typecheck && npm run build:all && npm run test:unit && npm run test:e2e && node --experimental-strip-types --no-warnings ./scripts/validate-build.ts && npm run validate:pagesmith",
    "validate": "npm run cicd",
    "validate:fast": "npm run check && npm run typecheck && npm run build:lib && npm run test:unit",
    "validate:pagesmith": "node --experimental-strip-types --no-warnings ./scripts/validate-pagesmith.ts",
    "validate:pagesmith:full": "node --experimental-strip-types --no-warnings ./scripts/validate-pagesmith.ts --full"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@viz-js/viz": "^3.25.0",
    "chokidar": "^5.0.0",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "mermaid": "^11.14.0",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rolldown": "^1.0.0-rc.13"
  },
  "devDependencies": {
    "@pagesmith/docs": "^0.9.8",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.15"
  },
  "peerDependencies": {
    "sharp": "^0.34.5"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "overrides": {
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "dompurify": ">=3.3.2",
    "lodash-es": ">=4.18.1",
    "nanoid": ">=3.3.8",
    "picomatch": ">=4.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.15",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.15"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.12.1",
  "ai": {
    "context": "./llms.txt",
    "fullContext": "./llms-full.txt",
    "agentsDir": "./ai-guidelines"
  }
}
