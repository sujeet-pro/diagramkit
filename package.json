{
  "name": "diagramkit",
  "version": "0.0.1",
  "description": "Diagram rendering CLI & library — convert .mermaid, .excalidraw, and .drawio to SVG/PNG/JPEG/WebP with light/dark mode support",
  "keywords": [
    "cli",
    "cli-tool",
    "dark-mode",
    "dark-mode-diagrams",
    "diagram",
    "diagram-renderer",
    "diagram-to-image",
    "draw.io",
    "drawio",
    "drawio-to-svg",
    "excalidraw",
    "excalidraw-to-svg",
    "headless-rendering",
    "incremental-build",
    "jpeg",
    "light-mode",
    "mermaid",
    "mermaid-to-svg",
    "png",
    "rendering",
    "sharp",
    "svg",
    "watch-mode",
    "webp"
  ],
  "homepage": "https://projects.sujeet.pro/diagramkit/",
  "bugs": {
    "url": "https://github.com/sujeet-pro/diagramkit/issues"
  },
  "license": "MIT",
  "author": "Sujeet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/diagramkit.git"
  },
  "bin": {
    "diagramkit": "./dist/cli/bin.mjs"
  },
  "files": [
    "dist",
    "skills",
    "llms.txt",
    "llms-full.txt"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./color": {
      "bun": "./src/color/index.ts",
      "import": "./dist/color/index.mjs",
      "types": "./dist/color/index.d.mts"
    },
    "./convert": {
      "bun": "./src/convert.ts",
      "import": "./dist/convert.mjs",
      "types": "./dist/convert.d.mts"
    }
  },
  "scripts": {
    "build": "vp pack",
    "build:docs": "npm run docs:build",
    "test": "vp test run",
    "test:unit": "vp test run src/ --pool forks --fileParallelism",
    "test:e2e": "vp test run e2e/ --pool forks --fileParallelism",
    "test:watch": "vp test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "vp config",
    "validate": "npm run check && npm run typecheck && npm run build && npm run build:docs && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "chokidar": "^5.0.0",
    "mermaid": "^11.6.0",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rolldown": "^1.0.0-rc.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.27.0",
    "sharp": "^0.33.0",
    "typescript": "^5.9.0",
    "vite-plus": "^0.1.13",
    "vitepress": "^1.6.0"
  },
  "peerDependencies": {
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.13"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.12.0"
}
