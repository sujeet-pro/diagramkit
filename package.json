{
  "name": "diagramkit",
  "version": "0.2.0",
  "description": "Diagram rendering CLI & library — convert .mermaid, .excalidraw, and .drawio to SVG/PNG/JPEG/WebP with light/dark mode support",
  "keywords": [
    "cli",
    "dark-mode",
    "diagram",
    "draw.io",
    "drawio",
    "excalidraw",
    "jpeg",
    "light-mode",
    "mermaid",
    "png",
    "rendering",
    "sharp",
    "svg",
    "webp"
  ],
  "license": "MIT",
  "bin": {
    "diagramkit": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "skills",
    "llms.txt",
    "llms-full.txt"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./color": {
      "bun": "./src/color/index.ts",
      "import": "./dist/color/index.js",
      "types": "./dist/color/index.d.ts"
    },
    "./convert": {
      "bun": "./src/convert.ts",
      "import": "./dist/convert.js",
      "types": "./dist/convert.d.ts"
    }
  },
  "scripts": {
    "build": "vp pack",
    "build:docs": "npm run docs:build",
    "test": "vp test run",
    "test:watch": "vp test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "vp config"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "chokidar": "^4.0.3",
    "mermaid": "^11.6.0",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rolldown": "^1.0.0-rc.11"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.27.0",
    "sharp": "^0.33.0",
    "typescript": "^5.9.0",
    "vite-plus": "^0.1.13",
    "vitepress": "^1.6.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.13"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.12.0"
}
