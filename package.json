{
  "name": "diagramkit",
  "version": "0.0.2",
  "description": "Diagram rendering CLI & library — convert .mermaid, .excalidraw, .drawio, and .dot/.gv Graphviz diagrams to SVG/PNG/JPEG/WebP with light/dark mode support",
  "keywords": [
    "cli",
    "cli-tool",
    "dark-mode",
    "dark-mode-diagrams",
    "diagram",
    "diagram-renderer",
    "diagram-to-image",
    "draw.io",
    "drawio",
    "drawio-to-svg",
    "excalidraw",
    "excalidraw-to-svg",
    "graphviz",
    "graphviz-to-svg",
    "headless-rendering",
    "incremental-build",
    "jpeg",
    "light-mode",
    "mermaid",
    "mermaid-to-svg",
    "png",
    "rendering",
    "sharp",
    "svg",
    "watch-mode",
    "webp"
  ],
  "homepage": "https://projects.sujeet.pro/diagramkit/",
  "bugs": {
    "url": "https://github.com/sujeet-pro/diagramkit/issues"
  },
  "license": "MIT",
  "author": "Sujeet Jaiswal (https://github.com/sujeet-pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/diagramkit.git"
  },
  "bin": {
    "diagramkit": "./dist/cli/bin.mjs"
  },
  "files": [
    "dist",
    "llms.txt",
    "llms-full.txt",
    "!dist/**/*.map"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./utils": {
      "import": "./dist/utils.mjs",
      "types": "./dist/utils.d.mts"
    },
    "./color": {
      "import": "./dist/color/index.mjs",
      "types": "./dist/color/index.d.mts"
    },
    "./convert": {
      "import": "./dist/convert.mjs",
      "types": "./dist/convert.d.mts"
    }
  },
  "scripts": {
    "build": "npm run lib:build && npm run docs:build",
    "preview": "npm run build && npm run docs:preview",
    "lib:build": "vp pack",
    "docs:dev": "pagesmith dev",
    "docs:build": "pagesmith build && cp llms.txt llms-full.txt gh-pages/",
    "docs:preview": "pagesmith preview",
    "test": "vp test run",
    "test:unit": "vp test run src/ --pool forks --fileParallelism",
    "test:e2e": "vp test run e2e/ --pool forks --fileParallelism",
    "test:watch": "vp test",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "vp config",
    "validate": "npm run check && npm run typecheck && npm run build && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@viz-js/viz": "^3.25.0",
    "chokidar": "^5.0.0",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "mermaid": "^11.13.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rolldown": "^1.0.0-rc.11"
  },
  "devDependencies": {
    "@pagesmith/docs": "^0.2.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.13"
  },
  "peerDependencies": {
    "sharp": "^0.34.5"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "overrides": {
    "dompurify": ">=3.3.2",
    "nanoid": ">=3.3.8",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.13"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.12.0"
}
