.env
.env.*
!.env.example

# Output of 'npm pack'
*.tgz

# TypeScript cache
*.tsbuildinfo

# Cache directories
.cache
.parcel-cache

# Temp files
*.temp.md
.temp/

# diagramkit output
# NOTE: rendered diagrams are committed so the docs site, GitHub README, and
# offline viewers always have an SVG to display without re-running the render
# pipeline. Keep `.diagramkit/` and `.diagrams/` tracked in this repo.
#
# The manifest is per-machine cache, not source of truth — keep it out of git.
**/.diagramkit/manifest.json

# Pagesmith docs build output
gh-pages/
docs-dist/

# IDE files
.vscode-test

# OS files
*.pid
*.seed
*.pid.lock

# Vite timestamp files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
