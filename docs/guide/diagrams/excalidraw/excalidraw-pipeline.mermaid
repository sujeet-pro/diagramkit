%% Diagram: Excalidraw Rendering Pipeline
%% Type: flowchart
flowchart LR
    source[".excalidraw JSON"] --> bundle["Bundle IIFE<br/>(rolldown)"]
    bundle --> browser_page["Browser Page<br/>__renderExcalidraw()"]
    browser_page -->|darkMode: false| light_svg[Light SVG]
    browser_page -->|darkMode: true| contrast[WCAG Contrast<br/>Post-Process]
    contrast --> dark_svg[Dark SVG]
