%% Diagram: Draw.io Rendering Pipeline
%% Type: flowchart
%%{init: {'htmlLabels': false, 'flowchart': {'htmlLabels': false}}}%%
flowchart TB
    source[".drawio XML"] --> bundle["Bundle IIFE<br/>(rolldown)"]
    bundle --> browser_page["Browser Page<br/>DOMParser"]
    browser_page --> parse_cells["Parse mxCells<br/>vertices + edges"]
    parse_cells -->|light colors| light_svg[Light SVG]
    parse_cells -->|adjustColorForDark| contrast[WCAG Contrast<br/>Post-Process]
    contrast --> dark_svg[Dark SVG]
