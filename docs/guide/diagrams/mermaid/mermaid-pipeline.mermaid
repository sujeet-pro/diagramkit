%% Diagram: Mermaid Rendering Pipeline
%% Type: flowchart
%%{init: {'htmlLabels': false, 'flowchart': {'htmlLabels': false}}}%%
flowchart LR
    source[".mermaid Source"] --> browser_pool[Browser Pool]
    browser_pool --> light_page["Light Page<br/>theme: default"]
    browser_pool --> dark_page["Dark Page<br/>theme: base +<br/>custom variables"]
    light_page --> light_svg[Light SVG]
    dark_page --> contrast[WCAG Contrast<br/>Post-Process]
    contrast --> dark_svg[Dark SVG]
