%% Diagram: Image Format Pipeline
%% Type: flowchart
flowchart LR
    source[Diagram Source] --> engine[Engine Render]
    engine --> svg[SVG]
    svg --> raster_check{Raster needed?}
    raster_check -->|No| svg_output[SVG Output]
    raster_check -->|Yes| sharp[sharp]
    sharp --> png[PNG]
    sharp --> jpeg[JPEG]
    sharp --> webp[WebP]
    sharp --> avif[AVIF]
