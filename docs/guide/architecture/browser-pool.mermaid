stateDiagram-v2
    [*] --> Idle : getPool()
    Idle --> Launching : acquire()
    Launching --> Active : browser ready
    Active --> Active : acquire() [refCount++]
    Active --> Draining : release() [refCount--]
    Draining --> Active : acquire()
    Draining --> IdleTimer : refCount = 0
    IdleTimer --> Disposing : 5s timeout
    IdleTimer --> Active : acquire()
    Disposing --> [*] : browser closed
    Active --> [*] : dispose(force)
