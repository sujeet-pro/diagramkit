%% Diagram: Dark Mode Rendering Strategy
%% Type: flowchart
%%{init: {'htmlLabels': false, 'flowchart': {'htmlLabels': false}}}%%
flowchart TB
    subgraph Mermaid
        direction TB
        mermaid_dark_page[Separate Dark Page<br/>mermaid.initialize dark] --> mermaid_render[Render SVG]
        mermaid_render --> mermaid_contrast[postProcessDarkSvg<br/>WCAG contrast fix]
    end

    subgraph Excalidraw
        direction TB
        excalidraw_page[Same Page<br/>darkMode: true] --> excalidraw_render[Render SVG<br/>native dark + contrast fix]
    end

    subgraph Draw.io
        direction TB
        drawio_page[Same Page<br/>darkMode: true] --> drawio_render[Render SVG<br/>browser color adjust + contrast fix]
    end

    subgraph Graphviz
        direction TB
        graphviz_wasm[Viz.js WASM] --> graphviz_contrast[postProcessDarkSvg<br/>WCAG contrast fix]
        graphviz_contrast --> graphviz_adapt[adaptGraphvizSvgForDarkMode<br/>black → dark-friendly colors]
    end
