%% Diagram: Render Pipeline
%% Type: flowchart
flowchart LR
    source[Source File] --> detect_type{Detect Type}
    detect_type -->|.mermaid .mmd| mermaid[Mermaid]
    detect_type -->|.excalidraw| excalidraw[Excalidraw]
    detect_type -->|.drawio .dio| drawio[Draw.io]
    detect_type -->|.dot .gv| graphviz[Graphviz]
    mermaid --> browser_pool[Browser Pool<br/>Chromium]
    excalidraw --> browser_pool
    drawio --> browser_pool
    graphviz --> viz_wasm[Viz.js WASM]
    browser_pool --> svg_output[SVG Output]
    viz_wasm --> svg_output
    svg_output --> raster_check{Raster?}
    raster_check -->|No| write_svg[Write SVG]
    raster_check -->|Yes| sharp_convert[sharp]
    sharp_convert --> raster_output[PNG / JPEG /<br/>WebP / AVIF]
    write_svg --> atomic_write[Atomic Write<br/>.tmp → rename]
    raster_output --> atomic_write
