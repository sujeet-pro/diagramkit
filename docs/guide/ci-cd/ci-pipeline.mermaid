%% Diagram: CI/CD Pipeline
%% Type: flowchart
%%{init: {'htmlLabels': false, 'flowchart': {'htmlLabels': false}}}%%
flowchart LR
    checkout[Checkout Code] --> npm_install[npm ci]
    npm_install --> cache_browser[Cache Playwright<br/>Browser Binary]
    cache_browser --> warmup[npx diagramkit warmup]
    warmup --> render["npx diagramkit render .<br/>--json --format svg"]
    render --> failure_check{Failures?}
    failure_check -->|No| upload[Upload Artifacts<br/>or Commit Outputs]
    failure_check -->|Yes| fail_build[Fail Build<br/>Report Errors]
