%% Diagram: CLI Command Structure
%% Type: flowchart
flowchart TB
    diagramkit[diagramkit] --> render[render]
    diagramkit --> warmup[warmup]
    diagramkit --> doctor[doctor]
    diagramkit --> init[init]
    diagramkit --> install_skill[--install-skill]
    diagramkit --> agent_help[--agent-help]

    render --> format_flag["--format svg,png,jpeg,webp,avif"]
    render --> theme_flag["--theme light,dark,both"]
    render --> watch_force["--watch / --force"]
    render --> output_flags["--output / --output-dir"]
    render --> json_flags["--json / --dry-run / --plan"]
    render --> other_flags["--type / --no-contrast / --scale"]
