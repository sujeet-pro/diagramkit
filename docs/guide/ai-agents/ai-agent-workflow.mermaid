%% Diagram: AI Agent Workflow
%% Type: flowchart
%% Note: kept as a flowchart (not a sequence diagram) so every step's label
%% sits inside an opaque, AA-contrast-checked box. Sequence diagrams float
%% message text on the page background, which gave low perceived contrast on
%% the docs site even though the SVG itself was technically AA-clean.
%%{init: {'htmlLabels': false, 'flowchart': {'htmlLabels': false}}}%%
flowchart TB
    install["1. Install diagramkit\nnpm add diagramkit"]:::action
    reference["2. Read REFERENCE.md\nnode_modules/diagramkit/REFERENCE.md"]:::read
    warmup["3. Warm up Playwright\nnpx diagramkit warmup"]:::action
    skills["4. Install agent skills\nnpx skills add sujeet-pro/diagramkit"]:::action
    write["5. Author diagram source\nfoo.mermaid / .drawio / .dot / .excalidraw"]:::author
    render["6. Render to images\nnpx diagramkit render . --json"]:::action
    validate["7. Validate output\nnpx diagramkit validate .diagramkit/ --recursive"]:::action
    inspect["8. Read JSON result\nrendered / skipped / failed counts"]:::read

    install --> reference
    reference --> warmup
    warmup --> skills
    skills --> write
    write --> render
    render --> validate
    validate --> inspect

    %% AA-compliant darker mid-tone palette: white text on each background
    %% passes WCAG 2.2 AA (>= 4.5:1).
    classDef action fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef read fill:#5C5C5C,stroke:#3D3D3D,color:#ffffff
    classDef author fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
